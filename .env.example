# RAG Multilingual - Vigeu vya Mazingira.

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=deepseek-coder:6.7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=granite-embedding:multilingual

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_NYARAKA_COLLECTION=nyaraka
CHROMA_MEMORY_COLLECTION=memory
CHROMA_CACHE_COLLECTION=cache

# Document Processing
DOCS_DIR=./data/documents
UPLOADS_DIR=./data/uploads
PROCESSED_DIR=./data/processed
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Memory Configuration
MAX_EPISODIC_MEMORY=100
CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_TOP_K=5
EPISODIC_TOP_K=3

# Mfumo
LOG_LEVEL=INFO
LANGUAGE=auto  # sw'=Swahili, en=English, auto=Detect automatically
APP_NAME=Binoblax
